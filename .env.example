# Copy this file to ".env" for local testing only. NEVER commit real secrets.
# On Azure, put these in App Service -> Settings -> Environment variables.

SECRET_KEY=
SESSION_COOKIE_SECURE=1
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin123!
LOCAL_RMS_IMPORT_TOKEN=

# Persistent storage on Azure Linux App Service
DATA_DIR=/home/eoms_data
BOL_DIR=/home/eoms_bol_files
UPLOAD_DIR=/home/eoms_uploads

# Azure Maps key used by EOMS map/geocoding
AZURE_MAPS_KEY=

# Azure should not scrape RMS directly. RMS blocks Azure/server browsers with 403.
# Azure receives local imports through /api/local-rms/import instead.
RMS_HEADLESS=1
RMS_MANUAL_LOGIN=0

# Local office PC settings. Use these in the local .env only.
# SESSION_COOKIE_SECURE=0
# RMS_HEADLESS=0
# RMS_MANUAL_LOGIN=1
# RMS_MANUAL_LOGIN_TIMEOUT_SECONDS=600
# RMS_BROWSER=chrome
# RMS_PROFILE_DIR=data/rms_browser_profile
# AZURE_EOMS_URL=https://eoms-dispatch-d5dcabencherf2ft.centralus-01.azurewebsites.net

# Optional RMS credentials. Better: use manual local RMS worker when RMS blocks Azure.
RMS_USERNAME=
RMS_PASSWORD=
