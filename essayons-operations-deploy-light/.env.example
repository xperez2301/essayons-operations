# Copy this file to ".env" and fill in real values. NEVER commit the real .env.
# Flask session signing key. Generate one with:  python -c "import secrets;print(secrets.token_hex(32))"
SECRET_KEY=

# Keep secure cookies enabled in production. Set to 0 only for local HTTP testing.
SESSION_COOKIE_SECURE=1

# First admin login (used only to seed the very first account / fallback login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMeToSomethingStrong!

# RMS (reusability.com) credentials for the scraping/automation features
RMS_USERNAME=
RMS_PASSWORD=

# Google Maps JavaScript / Geocoding API key (restrict it by HTTP referrer!)
GOOGLE_MAPS_API_KEY=

# Local dev only: set to 1 to enable Flask debug reloader
FLASK_DEBUG=0

# On Azure, point data at the persistent /home volume so redeploys don't wipe it:
# DATA_DIR=/home/data
# BOL_DIR=/home/bol_files
# UPLOAD_DIR=/home/uploads
